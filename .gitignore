# Dependencies
node_modules/

# TypeScript build output
dist/
build/
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime / temp files
*.tmp
*.temp
pids/
*.pid

# OS-generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor and IDE config
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Claude Code local settings (project-specific overrides, not shared)
.claude/settings.local.json

# Test artifacts
coverage/
.nyc_output/

# Audit runtime data — .audit/ is intentionally committed as the audit trail.
# Exclude test/scratch events that were never linked to a real commit.
# Real events are added via deliberate "git add .audit/..." audit commits.
.audit/events/*
.audit/functions/*
!.audit/events/.gitkeep
!.audit/functions/.gitkeep
